# Public site URL (no trailing slash)
NEXT_PUBLIC_SITE_URL=https://catsafeplant.com

# Amazon affiliate tag
NEXT_PUBLIC_AMAZON_TAG=catsafe-21

# Google Analytics 4 Measurement ID (G-XXXXXXXXXX)
NEXT_PUBLIC_GA_ID=

# OpenRouter API key for image generation (server-side only)
OPENROUTER_API_KEY=

# Google Search Console service-account JSON for the Indexing API (single line).
# Required only for `npm run submit-gsc -- --urls`. The sitemap ping does not need this.
GSC_SERVICE_ACCOUNT_JSON=
